{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=fornituras;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "App": {
    "Jwt": {
      "Secret": "dev-secret-key-for-local-development-only-min-32-chars",
      "ExpirationMs": 86400000
    },
    "Qr": {
      "Prefix": "FOR-",
      "SequenceLength": 6,
      "MaxBatchSize": 10000
    },
    "Pii": {
      "EncryptionKey": "0123456789abcdef0123456789abcdef",
      "BlindIndexKey": "dev-blind-index-key"
    },
    "Media": {
      "StoragePath": "media-store",
      "MaxSizeBytes": 5242880,
      "MaxWidth": 4096,
      "MaxHeight": 4096,
      "OfficerPhotoEnabled": false,
      "OrphanCleanupEnabled": false,
      "OrphanGraceHours": 24,
      "CleanupIntervalHours": 6
    },
    "RateLimit": {
      "ByCodigo": { "PermitLimit": 30, "WindowSeconds": 60 },
      "Public": { "PermitLimit": 60, "WindowSeconds": 60 }
    },
    "Seed": {
      "Admin": {
        "Enabled": true,
        "Name": "Administrador",
        "Email": "admin@fornituras.local",
        "Password": "Admin#2026"
      }
    },
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:4200",
        "http://localhost:8100",
        "capacitor://localhost"
      ]
    }
  }
}
