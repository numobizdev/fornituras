# Plantilla de variables de entorno — SOLO nombres, sin valores reales.
# Copia este archivo a ".env" (ignorado por git) y rellena los valores localmente.
# NUNCA pongas valores reales aquí ni commitees el .env.

# --- Base de datos (SQL Server 2022) ---
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# --- Seguridad / tokens ---
JWT_SECRET=
JWT_ACCESS_TTL_MINUTES=
JWT_REFRESH_TTL_DAYS=

# --- Firma de QR (HMAC) ---
QR_HMAC_SECRET=

# --- Cifrado de PII del padrón de elementos (ADR 0006) ---
# Clave AES en Base64 (32 bytes) para cifrar nombre/apellidos/CURP/RFC en reposo.
PII_ENCRYPTION_KEY=
# Clave del blind index (HMAC) para igualdad exacta de CURP/RFC.
OFFICER_BLIND_INDEX_KEY=

# --- Otros ---
APP_ENV=
