# Plantilla de variables de entorno — SOLO nombres, sin valores reales.
# Copia este archivo a ".env" (ignorado por git) y rellena los valores localmente.
# NUNCA pongas valores reales aquí ni commitees el .env.

# --- Base de datos (SQL Server 2022) ---
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# --- Seguridad / tokens ---
JWT_SECRET=
JWT_ACCESS_TTL_MINUTES=
JWT_REFRESH_TTL_DAYS=

# --- Firma de QR (HMAC) ---
QR_HMAC_SECRET=

# --- Cifrado de PII del padrón de elementos (ADR 0006) ---
# Clave AES en Base64 (32 bytes) para cifrar nombre/apellidos/CURP/RFC en reposo.
PII_ENCRYPTION_KEY=
# Clave del blind index (HMAC) para igualdad exacta de CURP/RFC.
OFFICER_BLIND_INDEX_KEY=

# --- Almacenamiento de fotos / media (017, ADR 0016) ---
# Directorio del servidor (FUERA del repo) donde se guardan los objetos cifrados AES-256-GCM.
MEDIA_STORAGE_PATH=
# Límite de peso del archivo aceptado, en bytes (objetivo 5 MB = 5242880).
MEDIA_MAX_SIZE_BYTES=
# Dimensiones máximas de la imagen saneada, en píxeles.
MEDIA_MAX_WIDTH=
MEDIA_MAX_HEIGHT=
# Gate de captura de foto de elemento (PII): "true" solo con base legal ADR 0003 (FR-015).
MEDIA_OFFICER_PHOTO_ENABLED=
# Las fotos reutilizan la clave PII_ENCRYPTION_KEY para el cifrado en reposo (ADR 0006/0016).

# --- Otros ---
APP_ENV=
